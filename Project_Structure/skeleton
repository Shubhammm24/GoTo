## 3. Database Schema

### Users Collection
```
{
  _id: ObjectId,
  name: String,
  email: String (unique),
  phone: String,
  password: String (hashed),
  profileImage: String,
  address: String,
  dateOfBirth: Date,
  role: Enum["customer", "driver", "vehicle_owner"],
  rating: Number (0-5),
  reviewCount: Number,
  isVerified: Boolean,
  identityProof: { docType, docNumber, expiryDate },
  createdAt: Date,
  updatedAt: Date
}
```

### Vehicles Collection
```
{
  _id: ObjectId,
  ownerId: ObjectId (ref: Users),
  vehicleType: Enum["car", "bike", "scooter"],
  licensePlate: String,
  brand: String,
  model: String,
  year: Number,
  seatCapacity: Number,
  registrationDoc: String,
  insuranceDoc: String,
  images: [String],
  rentalType: Enum["self-drive", "driver-operated", "both"],
  pricePerHour: Number,
  pricePerDay: Number,
  isAvailable: Boolean,
  location: { type: Point, coordinates: [lng, lat] },
  rating: Number,
  totalRides: Number,
  isActive: Boolean,
  createdAt: Date,
  updatedAt: Date
}
```

### Drivers Collection
```
{
  _id: ObjectId,
  userId: ObjectId (ref: Users),
  licenseNumber: String,
  licenseExpiry: Date,
  licenseDoc: String,
  backgroundCheck: Boolean,
  backgroundCheckDate: Date,
  bankDetails: { accountNumber, ifsc, accountName },
  isActive: Boolean,
  currentLocation: { type: Point, coordinates: [lng, lat] },
  isOnDuty: Boolean,
  completedRides: Number,
  rating: Number,
  earnings: { totalEarnings, pendingAmount, withdrawnAmount },
  documents: [String],
  createdAt: Date,
  updatedAt: Date
}
```

### Bookings Collection
```
{
  _id: ObjectId,
  customerId: ObjectId (ref: Users),
  vehicleId: ObjectId (ref: Vehicles),
  driverId: ObjectId (ref: Drivers) - optional for self-drive,
  pickupLocation: { address, coordinates: [lng, lat] },
  dropoffLocation: { address, coordinates: [lng, lat] },
  pickupTime: DateTime,
  dropoffTime: DateTime,
  rentalType: Enum["self-drive", "driver-operated"],
  vehicleType: Enum["car", "bike", "scooter"],
  estimatedDistance: Number (km),
  estimatedDuration: Number (minutes),
  actualDistance: Number,
  actualDuration: Number,
  baseFare: Number,
  distanceFare: Number,
  timeFare: Number,
  surgePricing: Number (multiplier),
  totalAmount: Number,
  status: Enum["requested", "confirmed", "driver_assigned", "pickup_pending", "in_progress", "completed", "cancelled"],
  paymentStatus: Enum["pending", "completed", "failed"],
  paymentMethod: Enum["credit_card", "debit_card", "wallet", "upi"],
  specialRequests: String,
  createdAt: Date,
  updatedAt: Date
}
```

### Payments Collection
```
{
  _id: ObjectId,
  bookingId: ObjectId (ref: Bookings),
  userId: ObjectId (ref: Users),
  amount: Number,
  currency: String,
  paymentMethod: String,
  transactionId: String,
  status: Enum["pending", "completed", "failed", "refunded"],
  stripePaymentIntentId: String,
  breakdown: {
    baseFare: Number,
    distanceFare: Number,
    timeFare: Number,
    surgePricing: Number,
    discount: Number,
    tax: Number,
    totalAmount: Number
  },
  createdAt: Date,
  updatedAt: Date
}
```

### Reviews Collection
```
{
  _id: ObjectId,
  bookingId: ObjectId (ref: Bookings),
  reviewerId: ObjectId (ref: Users),
  revieweeId: ObjectId (ref: Users),
  vehicleId: ObjectId (ref: Vehicles),
  rating: Number (1-5),
  comment: String,
  categories: {
    cleanliness: Number,
    communication: Number,
    drivingSkills: Number (optional),
    condition: Number
  },
  createdAt: Date,
  updatedAt: Date
}
```

### Tracking Collection (for real-time location)
```
{
  _id: ObjectId,
  bookingId: ObjectId (ref: Bookings),
  vehicleId: ObjectId (ref: Vehicles),
  location: { type: Point, coordinates: [lng, lat] },
  speed: Number,
  heading: Number,
  accuracy: Number,
  timestamp: DateTime,
  createdAt: Date (TTL index: 7 days)
}
```

